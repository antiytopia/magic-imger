{
  "name": "magic-imger",
  "version": "0.1.0",
  "private": true,
  "description": "SEO image pipeline tool on Node.js + sharp",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:gui": "node scripts/build-gui.mjs",
    "cli": "tsx src/cli/index.ts",
    "gui": "npm run build:gui && electron .gui-dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "electron": "^41.0.3",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "zustand": "^5.0.12"
  }
}
